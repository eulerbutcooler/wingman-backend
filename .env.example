# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=30s

# Database (Postgres)
DATABASE_URL=postgres://aeromentor:aeromentor@localhost:5432/aeromentor?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# NATS
NATS_URL=nats://localhost:4222
NATS_USER=
NATS_PASSWORD=

# MinIO (Object Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=course-files

# RAG Service
RAG_BASE_URL=http://localhost:8000
RAG_INTERNAL_TOKEN=changeme-internal-token

# JWT
JWT_ACCESS_SECRET=changeme-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=changeme-refresh-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Logging
LOG_LEVEL=debug
